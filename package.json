{
  "name": "week-27-todo-ap",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "db:generate":"bunx prisma generate --schema=packages/db/prisma/schema.prisma",
    "start:frontend":"cd apps/web && bun run start",
    "start:backend":"cd apps/backend && bun run start",
    "start:ws":"cd apps/ws && bun run start"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.16",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.13",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
  
}




